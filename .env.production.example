# Copy this file to a secure production env file and replace all placeholder values.

DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=peopalawan.com,www.peopalawan.com,localhost,127.0.0.1,[::1]
DJANGO_CSRF_TRUSTED_ORIGINS=https://peopalawan.com,https://www.peopalawan.com
DJANGO_SECRET_KEY=replace-with-a-long-random-secret-key
DJANGO_SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO:https
DJANGO_USE_X_FORWARDED_HOST=True
DJANGO_SECURE_SSL_REDIRECT=True
DJANGO_SESSION_COOKIE_SECURE=True
DJANGO_CSRF_COOKIE_SECURE=True
DJANGO_SECURE_HSTS_SECONDS=31536000
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=True
DJANGO_MEDIA_URL=/media/
DJANGO_MEDIA_ROOT=/shared/media

DJANGO_DB_ENGINE=django.db.backends.mysql
DJANGO_DB_NAME=peo_database
DJANGO_DB_USER=django_user
DJANGO_DB_PASSWORD=replace-with-strong-db-password
DJANGO_DB_HOST=db
DJANGO_DB_PORT=3306

MYSQL_ROOT_PASSWORD=replace-with-strong-root-password
MYSQL_DATABASE=peo_database
MYSQL_USER=django_user
MYSQL_PASSWORD=replace-with-strong-db-password

REDIS_URL=redis://redis:6379/0
DJANGO_CACHE_BACKEND=django_redis.cache.RedisCache
DJANGO_CACHE_LOCATION=redis://redis:6379/1
DJANGO_CHANNEL_LAYER_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Docker HTTPS override helpers
LETSENCRYPT_DIR=/etc/letsencrypt
CERTBOT_WEBROOT_DIR=./certbot/www
NGINX_CONF_PATH=./nginx/default-ssl.conf
HOST_HTTP_PORT=80
HOST_HTTPS_PORT=443
