# Django Settings for LAN Deployment
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,[::1],192.168.1.177,192.168.1.*,192.168.63.10,192.168.63.199,192.168.63.201,192.168.63.*
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://192.168.1.177:8000,http://192.168.63.10:8000,http://192.168.63.199:8000,http://192.168.63.201:8000
DJANGO_SECRET_KEY=your-super-secret-key-change-this-in-production-12345678
DJANGO_SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO:https
DJANGO_USE_X_FORWARDED_HOST=True
DJANGO_MEDIA_URL=/media/
DJANGO_MEDIA_ROOT=/shared/media

# Database Settings
DJANGO_DB_ENGINE=django.db.backends.mysql
DJANGO_DB_NAME=peo_database
DJANGO_DB_USER=django_user
DJANGO_DB_PASSWORD=django_pass
DJANGO_DB_HOST=db
DJANGO_DB_PORT=3306

# MySQL Settings
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=peo_database
MYSQL_USER=django_user
MYSQL_PASSWORD=django_pass

# Cache Settings
REDIS_URL=redis://redis:6379/0
DJANGO_CACHE_BACKEND=django_redis.cache.RedisCache
DJANGO_CACHE_LOCATION=redis://redis:6379/1
DJANGO_CHANNEL_LAYER_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
