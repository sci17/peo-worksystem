# Django Settings for LAN Deployment
DJANGO_DEBUG=False
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,[::1],192.168.1.177,192.168.1.*
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://192.168.1.177:8000
DJANGO_SECRET_KEY=your-super-secret-key-change-this-in-production-12345678
DJANGO_SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO:https
DJANGO_USE_X_FORWARDED_HOST=True

# Database Settings
DJANGO_DB_ENGINE=django.db.backends.sqlite3
DJANGO_DB_NAME=/app/db.sqlite3
DJANGO_DB_USER=django_user
DJANGO_DB_PASSWORD=django_pass
DJANGO_DB_HOST=db
DJANGO_DB_PORT=3306

# MySQL Settings
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=peo_database
MYSQL_USER=django_user
MYSQL_PASSWORD=django_pass

# Cache Settings
DJANGO_CACHE_BACKEND=django.core.cache.backends.filebased.FileBasedCache
DJANGO_CACHE_LOCATION=/app/.cache/django
