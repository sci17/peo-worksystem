# Django Settings
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=peopalawan.com,www.peopalawan.com,localhost,127.0.0.1,[::1],192.168.1.177
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://localhost:8080,https://localhost:8443,http://127.0.0.1:8000,http://127.0.0.1:8080,https://127.0.0.1:8443,https://peopalawan.com,https://www.peopalawan.com,http://192.168.1.177,http://192.168.1.177:80,http://192.168.1.177:8000,http://192.168.1.177:8080,https://192.168.1.177:8443
DJANGO_SECRET_KEY=your-super-secret-key-change-this-in-production-12345678
DJANGO_SECURE_PROXY_SSL_HEADER=HTTP_X_FORWARDED_PROTO:https
DJANGO_USE_X_FORWARDED_HOST=True
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SESSION_COOKIE_SECURE=False
DJANGO_CSRF_COOKIE_SECURE=False
DJANGO_SECURE_HSTS_SECONDS=0
DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS=True
DJANGO_SECURE_HSTS_PRELOAD=True
DJANGO_MEDIA_URL=/media/
DJANGO_MEDIA_ROOT=/shared/media

# Database Settings
DJANGO_DB_ENGINE=django.db.backends.mysql
DJANGO_DB_NAME=peo_database
DJANGO_DB_USER=django_user
DJANGO_DB_PASSWORD=django_pass
DJANGO_DB_HOST=db
DJANGO_DB_PORT=3306

# MySQL Settings
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=peo_database
MYSQL_USER=django_user
MYSQL_PASSWORD=django_pass

# Cache Settings
REDIS_URL=redis://redis:6379/0
DJANGO_CACHE_BACKEND=django_redis.cache.RedisCache
DJANGO_CACHE_LOCATION=redis://redis:6379/1
DJANGO_CHANNEL_LAYER_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Host port mapping workaround for Docker Desktop reserving 80/443
HOST_HTTP_PORT=8080
HOST_HTTPS_PORT=8443
