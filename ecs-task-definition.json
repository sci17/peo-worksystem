{
  "family": "peo-worksystem",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "512",
  "memory": "1024",
  "containerDefinitions": [
    {
      "name": "mysql",
      "image": "mysql:8.4",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 3306,
          "hostPort": 3306,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "MYSQL_DATABASE",
          "value": "peo_database"
        },
        {
          "name": "MYSQL_USER",
          "value": "django_user"
        }
      ],
      "secrets": [
        {
          "name": "MYSQL_ROOT_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT:secret:peo-db-root-password"
        },
        {
          "name": "MYSQL_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT:secret:peo-db-password"
        }
      ],
      "mountPoints": [
        {
          "sourceVolume": "mysql-data",
          "containerPath": "/var/lib/mysql"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/peo-worksystem",
          "awslogs-region": "REGION",
          "awslogs-stream-prefix": "mysql"
        }
      },
      "healthCheck": {
        "command": [
          "CMD-SHELL",
          "mysqladmin ping -h 127.0.0.1 -uroot || exit 1"
        ],
        "interval": 30,
        "timeout": 5,
        "retries": 3,
        "startPeriod": 60
      }
    },
    {
      "name": "web",
      "image": "YOUR_ACCOUNT.dkr.ecr.REGION.amazonaws.com/peo-worksystem-web:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8000,
          "hostPort": 8000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "DJANGO_DEBUG",
          "value": "False"
        },
        {
          "name": "DJANGO_ALLOWED_HOSTS",
          "value": "peopalawan.com,www.peopalawan.com"
        },
        {
          "name": "DJANGO_CSRF_TRUSTED_ORIGINS",
          "value": "https://peopalawan.com,https://www.peopalawan.com"
        },
        {
          "name": "DJANGO_SECURE_PROXY_SSL_HEADER",
          "value": "HTTP_X_FORWARDED_PROTO:https"
        },
        {
          "name": "DJANGO_USE_X_FORWARDED_HOST",
          "value": "True"
        },
        {
          "name": "DJANGO_SECURE_SSL_REDIRECT",
          "value": "True"
        },
        {
          "name": "DJANGO_SESSION_COOKIE_SECURE",
          "value": "True"
        },
        {
          "name": "DJANGO_CSRF_COOKIE_SECURE",
          "value": "True"
        },
        {
          "name": "DJANGO_SECURE_HSTS_SECONDS",
          "value": "31536000"
        },
        {
          "name": "DJANGO_SECURE_HSTS_INCLUDE_SUBDOMAINS",
          "value": "True"
        },
        {
          "name": "DJANGO_SECURE_HSTS_PRELOAD",
          "value": "True"
        },
        {
          "name": "DJANGO_DB_ENGINE",
          "value": "django.db.backends.mysql"
        },
        {
          "name": "DJANGO_DB_NAME",
          "value": "peo_database"
        },
        {
          "name": "DJANGO_DB_USER",
          "value": "django_user"
        },
        {
          "name": "DJANGO_DB_HOST",
          "value": "localhost"
        },
        {
          "name": "DJANGO_DB_PORT",
          "value": "3306"
        }
      ],
      "secrets": [
        {
          "name": "DJANGO_DB_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:REGION:ACCOUNT:secret:peo-db-password"
        }
      ],
      "mountPoints": [
        {
          "sourceVolume": "django-media",
          "containerPath": "/app/media"
        },
        {
          "sourceVolume": "django-static",
          "containerPath": "/app/staticfiles"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/peo-worksystem",
          "awslogs-region": "REGION",
          "awslogs-stream-prefix": "web"
        }
      },
      "dependsOn": [
        {
          "containerName": "mysql",
          "condition": "HEALTHY"
        }
      ]
    }
  ],
  "volumes": [
    {
      "name": "mysql-data",
      "efsVolumeConfiguration": {
        "fileSystemId": "fs-XXXXXXXXX",
        "transitEncryption": "ENABLED"
      }
    },
    {
      "name": "django-media",
      "efsVolumeConfiguration": {
        "fileSystemId": "fs-XXXXXXXXX",
        "transitEncryption": "ENABLED"
      }
    },
    {
      "name": "django-static",
      "efsVolumeConfiguration": {
        "fileSystemId": "fs-XXXXXXXXX",
        "transitEncryption": "ENABLED"
      }
    }
  ],
  "executionRoleArn": "arn:aws:iam::ACCOUNT:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::ACCOUNT:role/peoWorksystemTaskRole"
}
